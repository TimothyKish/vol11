    "molecular_c60":       "log(frequency_cm1 + 1) / log(k_geo)",
    "stellar_cycle":       "log(interval_days + 1) / log(k_geo)",
    "gravitational_wave":  "log(f_ring_hz + 1) / log(k_geo)",
    "planetary_atlantic":  "log(interval_hours + 1) / log(k_geo)",
    "planetary_gulf":      "log(interval_hours + 1) / log(k_geo)",
    "planetary_pacific":   "log(interval_hours + 1) / log(k_geo)",
    "planetary_indian":    "log(interval_hours + 1) / log(k_geo)",
    "planetary":           "log(interval_hours + 1) / log(k_geo)",
    "cmb_anisotropy":      "log(delta_T_uK + 1) / log(k_geo)",
    "galactic":            "log(vdisp + 1) / log(k_geo)",
    "stellar":             "log(dist_pc + 1) / log(k_geo)",
    "stellar_kinematic":   "log(v_perp + 1) / log(k_geo)",
    "stellar_luminosity":  "log(abs(M_G - median) + 1) / log(k_geo)",
    "stellar_colour":      "log(1 + max(bp_rp, 0.01)) / log(k_geo)",
    "stellar_rotation":    "log(period_days + 1) / log(k_geo)",
    "orbital":             "log(period_days + 1) / log(k_geo)",
    "orbital_radius":      "log(1 + pl_orbsmax_AU) / log(k_geo)",
    "orbital_mass":        "log(1 + pl_bmassj_Mj) / log(k_geo)",
